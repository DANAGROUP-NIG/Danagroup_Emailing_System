# ─── Source IMAP server (old mail server) ────────────────────────────────────
SOURCE_IMAP_HOST=mail.danagroup.com
SOURCE_IMAP_PORT=993
SOURCE_IMAP_TLS=true

# ─── Destination SMTP/IMAP server (DIMS + Postfix) ───────────────────────────
DEST_SMTP_HOST=mail.danagroup.net
DEST_SMTP_PORT=587
DEST_SMTP_USER=
DEST_SMTP_PASS=

# ─── DIMS API ─────────────────────────────────────────────────────────────────
DIMS_API_URL=http://localhost:8000/api
DIMS_ADMIN_EMAIL=admin@danagroup.net
DIMS_ADMIN_PASSWORD=

# ─── Migration options ────────────────────────────────────────────────────────
# Max concurrent accounts to migrate at once
CONCURRENCY=3
# How far back to migrate (days, 0 = all time)
DAYS_BACK=0
# Only migrate these folders (comma-separated; empty = all)
FOLDERS=INBOX,Sent,Drafts,Trash
