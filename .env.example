# ─────────────────────────────────────────────────────────────────────────────
# DIMS — Dana Internal Mail & Intranet System
# Root Environment Variables
# Copy this file to .env and fill in ALL values before running docker compose.
# ─────────────────────────────────────────────────────────────────────────────

# ═══════════════════════════════════════════════════════════════════════════════
# BACKEND (NestJS)
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=production
# Port the NestJS server listens on inside its container
PORT=8000
# Canonical URL of the application (used in emails, OG tags, etc.)
APP_URL=https://dims.danagroup.internal

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
# Hostname — matches the postgres service name in docker-compose
DB_HOST=postgres
DB_PORT=5432
DB_NAME=dims_db
DB_USER=dims_user
# REQUIRED — change to a strong password before first deploy
DB_PASSWORD=CHANGE_ME
# Set to "true" for cloud-hosted Postgres with TLS
DB_SSL=false

# ─── Redis ────────────────────────────────────────────────────────────────────
# Hostname — matches the redis service name in docker-compose
REDIS_HOST=redis
REDIS_PORT=6379
# Leave empty if Redis has no password (default for Docker)
REDIS_PASSWORD=

# ─── MinIO Object Storage ─────────────────────────────────────────────────────
# Hostname — matches the minio service name in docker-compose
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
# REQUIRED — change to strong credentials before first deploy
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
# Bucket name for email attachments and file uploads
MINIO_BUCKET=dims-attachments

# ─── Elasticsearch ────────────────────────────────────────────────────────────
# Hostname — matches the elasticsearch service name in docker-compose
ES_NODE=http://elasticsearch:9200

# ─── JWT ──────────────────────────────────────────────────────────────────────
# REQUIRED — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=CHANGE_ME
# REQUIRED — generate separately from JWT_SECRET
JWT_REFRESH_SECRET=CHANGE_ME
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── CORS / Session ──────────────────────────────────────────────────────────
# Allowed frontend origins (comma-separated). Wildcard subdomains supported.
# Examples: http://localhost, https://dims.danagroup.internal
FRONTEND_URL=http://localhost
# REQUIRED — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=CHANGE_ME

# ─── Logging ──────────────────────────────────────────────────────────────────
# One of: debug, info, warn, error
LOG_LEVEL=info

# ═══════════════════════════════════════════════════════════════════════════════
# FRONTEND (Next.js) — Build-time args
# These are passed as Docker build args AND runtime env in docker-compose.yml.
# You do NOT normally need to set them here — they are defined in
# docker-compose.yml. Listed here for documentation completeness.
# ═══════════════════════════════════════════════════════════════════════════════

# NEXT_PUBLIC_API_URL — Backend API URL as seen by the browser.
#   Use a relative path ("/api") when nginx proxies API requests.
#   Use an absolute URL ("http://localhost:8000/api") for direct access.
# NEXT_PUBLIC_API_URL=/api

# NEXT_PUBLIC_WS_URL — WebSocket URL for socket.io (browser-side).
# NEXT_PUBLIC_WS_URL=ws://localhost:3000

# NEXT_PUBLIC_APP_NAME — Display name in the UI.
# NEXT_PUBLIC_APP_NAME=DIMS — Dana Internal Mail

# INTERNAL_API_ORIGIN — Server-side only. Used by Next.js rewrites to proxy
#   /api/* to the backend container. Only needed when NEXT_PUBLIC_API_URL is
#   a relative path.
# INTERNAL_API_ORIGIN=http://api:8000

# ─── Cloudflare Tunnel (optional) ────────────────────────────────────────────
# Quick tunnel (zero config, random URL):
#   docker compose -f docker-compose.yml -f docker-compose.dev.yml -f docker-compose.tunnel.yml up
#   Watch logs for: "Your quick Tunnel has been created! Visit it at https://xxxx.trycloudflare.com"
#
# Named tunnel (persistent URL):
#   1. cloudflared tunnel login
#   2. cloudflared tunnel create dims-dev
#   3. Paste the token below and set CLOUDFLARE_HOSTNAME
CLOUDFLARE_TUNNEL_TOKEN=
# Set to your tunnel's public URL (e.g. https://dims-dev.yourdomain.com)
# Used to allow the tunnel origin in CORS
CLOUDFLARE_HOSTNAME=
# Set to your tunnel's WebSocket URL (e.g. wss://dims-dev.yourdomain.com)
# Only needed for named tunnels — quick tunnels auto-detect the origin
CLOUDFLARE_WS_URL=
