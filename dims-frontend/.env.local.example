# ─────────────────────────────────────────────────────────────────────────────
# DIMS Frontend Environment Variables
# Copy to .env.local for local development
# ─────────────────────────────────────────────────────────────────────────────

# Public vars (exposed to browser) — NEVER put secrets here
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_APP_NAME=DIMS — Dana Internal Mail

# Server-side only vars (middleware security)
# JWT_SECRET must match backend secret for middleware token verification
# This is required for JWT signature verification in middleware.ts
JWT_SECRET=your_jwt_secret_here

# Server-side only — used by Next.js rewrites to proxy /api/* to the backend.
# Only needed when NEXT_PUBLIC_API_URL is a relative path (e.g. "/api").
# In Docker Compose this is set to http://api:8000 automatically.
INTERNAL_API_ORIGIN=http://localhost:8000

# Optional: CSP violation report endpoint
# CSP_REPORT_URI=/api/csp-report
